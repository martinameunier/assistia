# Copy this file outside git history, then adapt values for your server.
# Example:
#   cp scripts/deploy-documentation.env.example .env.documentation
#   set -a && source .env.documentation && set +a

DOC_DEPLOY_TARGET=deploy@example.com
DOC_DEPLOY_PORT=22

# The script uploads site-documentaire into this remote parent folder.
# The final remote path will be:
#   $DOC_REMOTE_PARENT/site-documentaire
DOC_REMOTE_PARENT=/opt/assistia
DOC_REMOTE_SITE_NAME=site-documentaire

# The remote server uses docker-compose from inside site-documentaire.
DOC_COMPOSE_CMD=docker-compose

# Because the Dockerfile COPYs the documentation into the image,
# --build is needed for documentation changes to appear in Apache.
# To run exactly "docker-compose up -d", replace this with "-d".
DOC_COMPOSE_UP_ARGS="-d --build"
