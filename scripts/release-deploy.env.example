# Copy this file outside git history, then adapt values for your server.
# Example:
#   cp scripts/release-deploy.env.example .env.release
#   set -a && source .env.release && set +a

DEPLOY_TARGET=deploy@example.com
DEPLOY_PORT=22
DEPLOY_PATH=/opt/assistia

# Optional SSH key.
# DEPLOY_SSH_KEY=/Users/you/.ssh/id_ed25519

# Remote compose command. Use "sudo docker compose" if your deploy user needs sudo.
DEPLOY_COMPOSE_CMD=docker compose

# Default is safer: do not delete remote files missing locally.
DEPLOY_RSYNC_DELETE=0

# Extra Tauri args. Useful on unsigned Windows/macOS builds.
# TAURI_BUILD_ARGS=--no-sign
