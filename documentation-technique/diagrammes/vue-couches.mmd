flowchart TD
  User["Utilisateur"] --> UI["React UI - pages + composants"]
  UI --> Hooks["Hooks React - statuts, installations, modèles"]
  Hooks --> Store["Zustand - progression + logs"]
  Hooks --> Bridge["services/tauris.ts - invoke Tauri"]
  Bridge --> Commands["main.rs - commandes Tauri"]
  Commands --> Ollama["ollama.rs - chat + modèles + serveur"]
  Commands --> Comfy["comfyui.rs - modèles + génération + serveur"]
  Commands --> Agent["dev_agent.rs - Aider + diff"]
  Commands --> WebSearch["web_search.rs - recherche SearXNG"]
  Commands --> SearxngRuntime["searxng.rs - installation + serveur local"]
  Commands --> Install["installation.rs - uv + Python + composants"]
  Install --> Python["python.rs - détection Python/uv"]
  Install --> SearxngRuntime
  Ollama --> OllamaProcess["Processus Ollama - 127.0.0.1:11434"]
  Comfy --> ComfyProcess["Processus ComfyUI - 127.0.0.1:8188"]
  Agent --> AiderProcess["Processus Aider - projet utilisateur"]
  SearxngRuntime --> SearXNGProcess["Processus SearXNG - 127.0.0.1:8888"]
  WebSearch --> SearXNG["Instance SearXNG - API /search JSON"]
  SearXNGProcess --> SearXNG
  Commands --> Events["Événements Tauri - launcher-log + launcher-status"]
  Events --> Store
